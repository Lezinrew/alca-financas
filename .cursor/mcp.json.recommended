{
  "mcpServers": {
    "supabase": {
      "url": "https://mcp.supabase.com/mcp?project_ref=blutjlzyvhdvnkvrzdcm&read_only=true",
      "_comment": "Acesso read-only ao banco Supabase (queries, schema)"
    },
    "hostinger-mcp": {
      "command": "npx",
      "args": ["hostinger-api-mcp@latest"],
      "env": {
        "API_TOKEN": "JKpDlVDOZpOzYmpEf9mjFXAyVrntEel30Xn5S6rDb9e9612c"
      },
      "_comment": "Gerenciamento do VPS Hostinger (deploy, status, logs)"
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "<SEU_GITHUB_TOKEN_AQUI>"
      },
      "_comment": "Operações GitHub (PRs, issues, workflows, releases)",
      "_disabled": true
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/Users/lezinrew/Projetos/alca-financas"],
      "_comment": "Acesso otimizado ao sistema de arquivos do projeto",
      "_disabled": true
    },
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres"],
      "env": {
        "DATABASE_URL": "postgresql://postgres.<project_ref>:<password>@<region>.pooler.supabase.com:6543/postgres"
      },
      "_comment": "Acesso direto ao PostgreSQL (alternativa ao Supabase MCP)",
      "_disabled": true
    }
  },
  "_notes": {
    "security": "Nunca commitar este arquivo! Está no .gitignore.",
    "performance": "Desabilitar MCPs não usados (_disabled: true) para melhor performance",
    "github_token": "Criar em: https://github.com/settings/tokens (scopes: repo, workflow, read:org)",
    "database_url": "Obter em: Supabase Dashboard -> Project Settings -> Database -> Connection String (Session)"
  }
}
