# Backend - variáveis usadas quando o app roda a partir de backend/
# Copie para backend/.env ou use o .env na raiz do projeto.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-if-hs256
# SUPABASE_JWT_AUD=authenticated

SECRET_KEY=your-secret-key-min-32-chars
# JWT_SECRET é legado (JWT próprio da app). No modo Supabase-only, não é necessário.
# JWT_SECRET=your-jwt-secret-min-32-chars

FLASK_ENV=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173
