# ===========================================
# Alça Finanças - Template de variáveis de ambiente
# Copie para .env e preencha com seus valores. NUNCA commite o .env!
# ===========================================

# Supabase (obrigatório)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-dashboard
SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard

# Backend - Secrets (gerar com: openssl rand -hex 32)
SECRET_KEY=your-secret-key-min-32-chars
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRES_HOURS=24

# Flask
FLASK_ENV=development
BACKEND_PORT=8001
HOST=0.0.0.0

# CORS (origens permitidas, separadas por vírgula)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Frontend (URL do app para redirects/OAuth)
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:8001

# Build do frontend (usado no deploy)
VITE_API_URL=http://localhost:8001
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard

# OAuth Google (opcional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Email (opcional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# OpenClaw / Chatbot (opcional)
# OPENCLAW_GATEWAY_TOKEN=
# OPENCLAW_URL=http://localhost:40394

# Pular init do DB em CI/testes
# SKIP_DB_INIT=false
