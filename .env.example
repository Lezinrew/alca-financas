# ===========================================
# Alça Finanças — .env.example
# ===========================================
# Copie para .env e preencha com seus valores.
# NUNCA commite o .env no git!
#
# Gerar secrets: openssl rand -hex 32
# ===========================================

# =============================================
# 1. AMBIENTE
# =============================================
NODE_ENV=local
FLASK_ENV=development
BACKEND_PORT=8001
HOST=0.0.0.0

# =============================================
# 2. SUPABASE (OBRIGATÓRIO)
# =============================================
# Obter em: https://app.supabase.com/project/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-from-dashboard
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-dashboard

# ⚠️ P0 CRÍTICO: validação local do access token (backend + chatbot)
# O backend escolhe o modo pelo header JWT `alg`:
#   - HS256 → obrigatório SUPABASE_JWT_SECRET (mesmo projeto que SUPABASE_URL).
#   - RS256/ES256 → JWKS em {SUPABASE_URL}/auth/v1/.well-known/jwks.json (secret pode ficar vazio).
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-min-32-chars
# SUPABASE_JWT_AUD=authenticated

# =============================================
# 3. BACKEND — SECRETS
# =============================================
# Gerar: openssl rand -hex 32
# Obrigatório para Flask (sessão/cookies). Também usado como fallback de assinatura
# para JWTs legados internos da app (ex.: OAuth callback) quando JWT_SECRET não existir.
SECRET_KEY=your-flask-secret-key-min-32-chars

# JWT_SECRET: NÃO use no fluxo atual. Validação de API = SUPABASE_JWT_SECRET (verify_supabase_jwt).
# Se ainda existir no .env legado, auth_utils usa-o só antes de SECRET_KEY para assinar JWTs internos antigos.
JWT_EXPIRATION=7d
JWT_EXPIRES_HOURS=24

# =============================================
# 4. CORS — ORIGENS PERMITIDAS
# =============================================
# Dev: inclua localhost e 127.0.0.1 (origens distintas para CORS)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173,https://alcahub.cloud,https://www.alcahub.cloud

# =============================================
# 5. FRONTEND — VITE (build/deploy)
# =============================================
# Estas variáveis são lidas pelo frontend durante o build
VITE_API_URL=http://localhost:8001
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-from-dashboard

# Cadastro / confirmação por e-mail (Supabase Auth): URL dos links no e-mail.
# Se omitido, o app usa <origem do browser>/login (ex.: http://localhost:3000/login).
# Adicione o mesmo valor em Supabase → Authentication → URL Configuration → Redirect URLs.
# VITE_AUTH_EMAIL_REDIRECT_TO=http://localhost:3000/login

# Chatbot (Backend Flask - P0 #1)
# ⚠️ Migrado de FastAPI separado para backend Flask
VITE_CHAT_API_URL=http://localhost:8001/api/chatbot
# VITE_CHAT_WS_URL=ws://localhost:8001/api/chatbot/ws  # Futuro: implementar WebSocket no Flask

# Feature Flags
VITE_ENABLE_CHATBOT=true
VITE_ENABLE_IMPORT_CSV=true
VITE_ENABLE_ONBOARDING=true

# =============================================
# 6. CHATBOT — BACKEND FLASK (P0 #1)
# =============================================
# ⚠️ P0 CRÍTICO: chatbot e backend validam usando SUPABASE_JWT_SECRET
OPENCLAW_GATEWAY_URL=http://localhost:8080
OPENCLAW_API_KEY=your-openclaw-api-key

# FastAPI separado (services/chatbot/) - ARQUIVADO
# ⚠️ Não usar JWT_SECRET/CHATBOT_JWT_SECRET; usar somente SUPABASE_JWT_SECRET
# CHATBOT_JWT_SECRET=deprecated-use-supabase-jwt-secret
# CHATBOT_HOST=0.0.0.0
# CHATBOT_PORT=8100

# =============================================
# 7. OAUTH — OPCIONAL
# =============================================
# Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# Apple
APPLE_CLIENT_ID=your-apple-client-id
APPLE_CLIENT_SECRET=your-apple-client-secret

# =============================================
# 8. EMAIL / SMTP — OPCIONAL
# =============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@alcahub.cloud

# =============================================
# 9. RATE LIMITING — OPCIONAL
# =============================================
RATELIMIT_ENABLED=true
RATELIMIT_DEFAULT=100 per hour
RATELIMIT_CHATBOT=20 per minute

# =============================================
# 10. TESTES — VALORES DE EXEMPLO
# =============================================
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=change-me
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=change-me

# =============================================
# 11. DEPLOY / VPS — PRODUÇÃO
# =============================================
# Usado por scripts de deploy (scripts/prod/deploy.sh)
DEPLOY_USER=root
DEPLOY_HOST=your-vps-ip-or-hostname
DEPLOY_PATH=/var/www/alca-financas
DEPLOY_SSH_KEY_PATH=~/.ssh/id_ed25519

# VPS Hostinger
VPS_HOSTINGER_HOST=srv1353242.hostinger.com
VPS_SSH_USER=root

# Domínios de produção
PROD_API_URL=https://api.alcahub.cloud
PROD_WEB_URL=https://alcahub.cloud
PROD_CHATBOT_URL=https://chat.alcahub.com.br

# =============================================
# 12. DOCKER COMPOSE — CONFIGURAÇÕES
# =============================================
COMPOSE_PROJECT_NAME=alca-financas
DOCKER_BUILDKIT=1

# =============================================
# 13. MONITORAMENTO / LOGS — OPCIONAL
# =============================================
# SENTRY_DSN=https://your-sentry-dsn
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# POSTHOG_API_KEY=your-posthog-key
# POSTHOG_HOST=https://app.posthog.com

# =============================================
# 14. DATABASE — CONEXÃO DIRETA (OPCIONAL)
# =============================================
# Supabase DB connection (readonly para MCP server)
# Obter em: Settings → Database → Connection string
SUPABASE_CONNECTION_STRING_READ_ONLY=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres

# =============================================
# 15. N8N — AUTOMAÇÕES (OPCIONAL)
# =============================================
N8N_HOST=localhost
N8N_PORT=5678
N8N_WEBHOOK_URL=http://localhost:5678/webhook/

# =============================================
# CHECKLIST PRÉ-DEPLOY
# =============================================
# [ ] SUPABASE_JWT_SECRET definido e igual em todos os serviços (P0)
# [ ] JWT_SECRET/CHATBOT_JWT_SECRET não utilizados em validação (P0)
# [ ] VITE_API_URL correto para o ambiente
# [ ] CORS_ORIGINS inclui domínio de produção
# [ ] build/frontend/ gerado antes de deploy
# [ ] .env NÃO commitado no git
# [ ] Secrets gerados com openssl rand -hex 32
# =============================================
