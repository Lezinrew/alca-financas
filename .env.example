# ===========================================
# Alça Finanças - Template (baseado nos arquivos locais)
# Copie para .env e preencha. NUNCA commite o .env!
# ===========================================

# Ambiente de execução
NODE_ENV=local

# URLs - Local
LOCAL_API_URL=http://localhost:8001
LOCAL_WEB_URL=http://localhost:3000

# URLs - Produção (exemplo)
PROD_API_URL=https://api.alcahub.cloud
PROD_WEB_URL=https://alcahub.cloud
CORS_ORIGINS=https://alcahub.cloud,https://www.alcahub.cloud

# Supabase (obrigatório)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-dashboard
SUPABASE_ANON_KEY=your-anon-key-from-dashboard

# Backend - Secrets (gerar: openssl rand -hex 32)
SECRET_KEY=your-secret-key-min-32-chars
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRATION=7d
JWT_EXPIRES_HOURS=24

# Flask
FLASK_ENV=development
BACKEND_PORT=8001
HOST=0.0.0.0

# Frontend / OAuth redirects
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:8001

# Build frontend (deploy)
VITE_API_URL=http://localhost:8001
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-from-dashboard

# OAuth Google (opcional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth Microsoft (opcional)
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# OAuth Apple (opcional)
APPLE_CLIENT_ID=your-apple-client-id
APPLE_CLIENT_SECRET=your-apple-client-secret

# Email (opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
# SMTP_FROM=optional-override@example.com

# Testes (valores de exemplo)
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=change-me
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=change-me

# Deploy (quando usar scripts que leem isso)
DEPLOY_USER=root
DEPLOY_HOST=your-server-ip
DEPLOY_PATH=/var/www/alca-financas

# Opcionais
# SENTRY_DSN=
# GOOGLE_ANALYTICS_ID=
# USE_SUPABASE_AUTH=true
# SKIP_DB_INIT=false
# SUPABASE_DB_URL=postgresql://...
# OPENCLAW_GATEWAY_TOKEN=
# OPENCLAW_URL=http://localhost:40394
